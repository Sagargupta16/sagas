---
import '@fontsource-variable/eczar/index.css';
import '@fontsource-variable/literata/index.css';
import '../styles/global.css';
import { withBase } from '../lib/shelf';

interface Props {
  title: string;
  description: string;
  ogType?: 'website' | 'article' | 'book';
}

const { title, description, ogType = 'website' } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const siteName = 'sagas';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: new URL(withBase('/'), Astro.site).href,
  description:
    'Original fantasy, fan fiction, and essays by Sagar Gupta, written in the open one chapter at a time.',
  inLanguage: 'en',
  author: {
    '@type': 'Person',
    name: 'Sagar Gupta',
    url: 'https://sagargupta.online',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="sagas"
      href={new URL(withBase('/rss.xml'), Astro.site)}
    />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>
    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />
  </head>
  <body>
    <header>
      <nav class="wrap">
        <a href={withBase('/')} class="wordmark">
          <svg
            class="flame"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            aria-hidden="true"
            fill="currentColor"
          >
            <path
              d="M12 2c1.2 3.3-1.8 4.8-1.8 7.4 0 1.3 1 2.1 1 2.1s-.4-2.2 1.3-3.4c1.9 2 3.5 3.6 3.5 6.2A6 6 0 0 1 6 14.3C6 9.8 11 8.4 12 2Z"
            ></path>
          </svg>
          <span>sagas</span>
        </a>
        <a href={new URL(withBase('/rss.xml'), Astro.site)} class="feed">Feed</a>
      </nav>
    </header>
    <slot />
    <footer>
      <div class="wrap foot-grid">
        <div class="foot-brand">
          <a href={withBase('/')} class="wordmark foot-mark">
            <svg
              class="flame"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              aria-hidden="true"
              fill="currentColor"
            >
              <path
                d="M12 2c1.2 3.3-1.8 4.8-1.8 7.4 0 1.3 1 2.1 1 2.1s-.4-2.2 1.3-3.4c1.9 2 3.5 3.6 3.5 6.2A6 6 0 0 1 6 14.3C6 9.8 11 8.4 12 2Z"
              ></path>
            </svg>
            <span>sagas</span>
          </a>
          <p class="foot-lead">A living library of unfinished books.</p>
        </div>

        <nav class="foot-col" aria-label="Shelves">
          <h2>Shelves</h2>
          <a href={withBase('/#original-fantasy')}>Original Fantasy</a>
          <a href={withBase('/#fan-fiction')}>Fan Fiction</a>
          <a href={withBase('/#essays')}>Essays</a>
        </nav>

        <nav class="foot-col" aria-label="Follow">
          <h2>Follow</h2>
          <a href={new URL(withBase('/rss.xml'), Astro.site)}>RSS feed</a>
          <a href="https://sagargupta.online">Sagar Gupta</a>
          <a href="https://github.com/Sagargupta16/sagas">Source on GitHub</a>
        </nav>

        <div class="foot-col">
          <h2>About</h2>
          <p class="foot-fine">
            Fan fiction is free and non-commercial, always. Prose licensed <a
              href="https://creativecommons.org/licenses/by-nc-nd/4.0/"
              >CC BY-NC-ND 4.0</a
            >; code MIT.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--glass-strong);
    backdrop-filter: blur(var(--blur)) saturate(1.3);
    -webkit-backdrop-filter: blur(var(--blur)) saturate(1.3);
    border-bottom: 1px solid var(--glass-border);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-sm);
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .flame {
    width: 1em;
    height: 1em;
    color: var(--flame);
    flex: none;
  }

  .feed {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    text-decoration: none;
    padding: 0.2em 0.7em;
    border: 1px solid var(--line);
    border-radius: 999px;
    transition:
      color 180ms var(--ease-out),
      border-color 180ms var(--ease-out);
  }

  .feed:hover {
    color: var(--flame);
    border-color: var(--flame-dim);
  }

  footer {
    border-top: 1px solid var(--line);
    margin-top: auto;
    background: var(--surface-sunken);
  }

  .foot-grid {
    padding-block: var(--space-2xl) var(--space-xl);
    display: grid;
    gap: var(--space-xl) var(--space-lg);
    grid-template-columns: 1fr;
  }

  @media (min-width: 40rem) {
    .foot-grid {
      grid-template-columns: 1.6fr 1fr 1fr 1.4fr;
    }
  }

  .foot-mark {
    font-size: var(--text-lg);
  }

  .foot-lead {
    margin-top: var(--space-sm);
    font-family: var(--font-display);
    color: var(--ink-soft);
    max-width: 24ch;
  }

  .foot-col {
    display: grid;
    gap: var(--space-xs);
    align-content: start;
  }

  .foot-col h2 {
    font-size: var(--text-sm);
    font-variant-caps: all-small-caps;
    letter-spacing: 0.1em;
    color: var(--ink-faint);
    font-weight: 600;
  }

  .foot-col a {
    color: var(--ink-soft);
    text-decoration: none;
    font-size: var(--text-sm);
    width: fit-content;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .foot-col a:hover {
    color: var(--flame);
  }

  .foot-fine {
    font-size: var(--text-sm);
    color: var(--ink-soft);
    max-width: var(--measure);
  }
</style>
