---
import '@fontsource-variable/eczar/index.css';
import '@fontsource-variable/literata/index.css';
import '../styles/global.css';
import { withBase } from '../lib/shelf';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="sagas"
      href={new URL(withBase('/rss.xml'), Astro.site)}
    />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav class="wrap">
        <a href={withBase('/')} class="wordmark">
          <svg
            class="flame"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            aria-hidden="true"
            fill="currentColor"
          >
            <path
              d="M12 2c1.2 3.3-1.8 4.8-1.8 7.4 0 1.3 1 2.1 1 2.1s-.4-2.2 1.3-3.4c1.9 2 3.5 3.6 3.5 6.2A6 6 0 0 1 6 14.3C6 9.8 11 8.4 12 2Z"
            ></path>
          </svg>
          <span>sagas</span>
        </a>
        <a href={new URL(withBase('/rss.xml'), Astro.site)} class="feed">Feed</a>
      </nav>
    </header>
    <slot />
    <footer>
      <div class="wrap">
        <p class="foot-lead">A living library of unfinished books.</p>
        <p class="foot-fine">
          Written in the open by <a href="https://sagargupta.online"
            >Sagar Gupta</a
          >. Fan fiction is free and non-commercial, always. Prose licensed <a
            href="https://creativecommons.org/licenses/by-nc-nd/4.0/"
            >CC BY-NC-ND 4.0</a
          >.
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in oklab, var(--surface) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--line-soft);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-sm);
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .flame {
    width: 1em;
    height: 1em;
    color: var(--flame);
    flex: none;
  }

  .feed {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    text-decoration: none;
    padding: 0.2em 0.7em;
    border: 1px solid var(--line);
    border-radius: 999px;
    transition:
      color 180ms var(--ease-out),
      border-color 180ms var(--ease-out);
  }

  .feed:hover {
    color: var(--flame);
    border-color: var(--flame-dim);
  }

  footer {
    border-top: 1px solid var(--line);
    margin-top: auto;
    background: var(--surface-sunken);
  }

  footer .wrap {
    padding-block: var(--space-xl);
    display: grid;
    gap: var(--space-xs);
  }

  .foot-lead {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--ink);
  }

  .foot-fine {
    font-size: var(--text-sm);
    color: var(--ink-soft);
    max-width: var(--measure);
  }
</style>
