---
// Audiobook player -- styled native <audio>, accessible, mobile-friendly, zero JS.
interface Props {
  url: string;
  title: string;
  label?: string;
}
const { url, title, label = 'Listen to this chapter' } = Astro.props;
---

<section class="audio glass" aria-label={`Audiobook for ${title}`}>
  <div class="audio-head">
    <span class="audio-icon" aria-hidden="true">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M3 10v4h4l5 5V5L7 10H3z"></path>
        <path d="M16 8a5 5 0 0 1 0 8"></path>
        <path d="M19 5a9 9 0 0 1 0 14"></path>
      </svg>
    </span>
    <div class="audio-text">
      <p class="audio-label">{label}</p>
      <p class="audio-title">{title}</p>
    </div>
  </div>
  <audio controls preload="none" src={url}>
    Your browser does not support audio playback.
    <a href={url} download>Download the audio</a>.
  </audio>
</section>

<style>
  .audio {
    margin-block: var(--space-xl);
    padding: var(--space-md) var(--space-lg);
    display: grid;
    gap: var(--space-sm);
  }

  .audio-head {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .audio-icon {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    flex: none;
    border-radius: 999px;
    background: var(--flame-wash);
    color: var(--flame);
  }

  .audio-icon svg {
    width: 1.2rem;
    height: 1.2rem;
  }

  .audio-label {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--ink);
  }

  .audio-title {
    font-size: var(--text-sm);
    color: var(--ink-soft);
  }

  audio {
    width: 100%;
    height: 40px;
  }
</style>
