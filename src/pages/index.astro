---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import {
  SHELVES,
  STATUS_LABELS,
  bookSlug,
  formatDate,
  type Shelf,
} from '../lib/shelf';

const books = await getCollection('books');
const chapters = await getCollection('chapters');

const chapterCount = (slug: string) =>
  chapters.filter((c) => bookSlug(c.id) === slug).length;

const shelves = (Object.keys(SHELVES) as Shelf[]).map((shelf) => ({
  shelf,
  ...SHELVES[shelf],
  books: books
    .filter((b) => b.data.shelf === shelf)
    .sort((a, b) => b.data.startedOn.valueOf() - a.data.startedOn.valueOf()),
}));
---

<Base
  title="sagas -- a living library of unfinished books"
  description="Original fantasy, fan fiction, and essays by Sagar Gupta, written in the open one chapter at a time."
>
  <main>
    <section class="hero rise">
      <h1>A living library of unfinished books.</h1>
      <p class="lede">
        Original fantasy, fan fiction, and essays -- written in the open, one
        chapter at a time. Every draft is public. Every revision is honest.
      </p>
    </section>

    {
      shelves.map(({ shelf, name, blurb, books }) => (
        <section class="shelf rise">
          <h2>{name}</h2>
          <p class="blurb">{blurb}</p>
          <ul>
            {books.map((book) => {
              const slug = bookSlug(book.id);
              const count = chapterCount(slug);
              return (
                <li>
                  <a href={`/books/${slug}`} class="book-title">
                    {book.data.title}
                  </a>
                  <p class="synopsis">{book.data.synopsis}</p>
                  <p class="meta">
                    <span class:list={['status', book.data.status]}>
                      {STATUS_LABELS[book.data.status]}
                    </span>
                    {count > 0 && (
                      <span>
                        {count} chapter{count === 1 ? '' : 's'}
                      </span>
                    )}
                    {book.data.universe && <span>{book.data.universe}</span>}
                    <span>since {formatDate(book.data.startedOn)}</span>
                  </p>
                </li>
              );
            })}
          </ul>
          {shelf === 'fanfic' && (
            <p class="note">
              Everything on this shelf is transformative fan work: free,
              non-commercial, and unaffiliated with the rights holders of the
              universes it borrows.
            </p>
          )}
        </section>
      ))
    }
  </main>
</Base>

<style>
  .hero {
    margin-bottom: var(--space-3xl);
  }

  .hero h1 {
    font-size: var(--text-2xl);
    max-width: 18ch;
  }

  .lede {
    margin-top: var(--space-lg);
    font-size: var(--text-lg);
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 46ch;
  }

  .shelf {
    margin-bottom: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--line);
  }

  .shelf h2 {
    font-size: var(--text-xl);
  }

  .blurb {
    margin-top: var(--space-2xs);
    color: var(--ink-soft);
    font-size: var(--text-sm);
    font-style: italic;
  }

  ul {
    list-style: none;
    margin: var(--space-lg) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-xl);
  }

  .book-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--ink);
    text-decoration-thickness: 1px;
  }

  .synopsis {
    margin-top: var(--space-xs);
    max-width: var(--measure);
  }

  .meta {
    margin-top: var(--space-xs);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-md);
    font-size: var(--text-sm);
    color: var(--ink-soft);
  }

  .status {
    color: var(--flame);
    font-variant-caps: all-small-caps;
    letter-spacing: 0.06em;
  }

  .note {
    margin-top: var(--space-lg);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    max-width: var(--measure);
  }
</style>
