---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import FormatBadges from '../components/FormatBadges.astro';
import {
  SHELVES,
  STATUS_LABELS,
  bookSlug,
  chapterSlug,
  formatDate,
  withBase,
  type Shelf,
} from '../lib/shelf';

const books = await getCollection('books');
const chapters = await getCollection('chapters');

const chapterCount = (slug: string) =>
  chapters.filter((c) => bookSlug(c.id) === slug).length;

// Lightweight map for the client-side "Continue reading" banner:
// book slug -> { title, chapters: [{ id, title, href }] }.
const readingMap = Object.fromEntries(
  books.map((b) => {
    const slug = bookSlug(b.id);
    const chs = chapters
      .filter((c) => bookSlug(c.id) === slug)
      .sort((a, c) => a.data.order - c.data.order)
      .map((c) => ({
        id: chapterSlug(c.id),
        title: c.data.title,
        href: withBase(`/books/${slug}/${chapterSlug(c.id)}`),
      }));
    return [slug, { title: b.data.title, chapters: chs }];
  }),
);

const shelves = (Object.keys(SHELVES) as Shelf[]).map((shelf) => ({
  shelf,
  ...SHELVES[shelf],
  books: books
    .filter((b) => b.data.shelf === shelf)
    .sort((a, b) => b.data.startedOn.valueOf() - a.data.startedOn.valueOf()),
}));

const totalBooks = books.length;
const totalChapters = chapters.length;
---

<Base
  title="sagas -- a living library of unfinished books"
  description="Original fantasy, fan fiction, and essays by Sagar Gupta, written in the open one chapter at a time."
>
  <main>
    <section class="hero rise">
      <p class="eyebrow">Work in progress</p>
      <h1>A living library of unfinished books.</h1>
      <p class="lede">
        Original fantasy, fan fiction, and essays -- written in the open, one
        chapter at a time. Every draft is public. Every revision is honest.
      </p>
      <p class="stats">
        <span><strong>{totalBooks}</strong> books taking shape</span>
        <span><strong>{totalChapters}</strong> chapters written</span>
        <span><strong>3</strong> shelves</span>
      </p>
    </section>

    <a class="continue glass" data-continue hidden href="#">
      <span class="continue-eyebrow">Continue reading</span>
      <span class="continue-title" data-continue-title></span>
      <span class="continue-meta" data-continue-meta></span>
    </a>

    <script type="application/json" data-reading-map set:html={JSON.stringify(readingMap)}
    ></script>
    <script>
      const el = document.querySelector('[data-continue]') as HTMLAnchorElement | null;
      const mapEl = document.querySelector('[data-reading-map]');
      if (el && mapEl) {
        let map: Record<string, { title: string; chapters: { id: string; title: string; href: string }[] }> = {};
        try {
          map = JSON.parse(mapEl.textContent || '{}');
        } catch {}
        // find the most recently-read book by its saved timestamp
        let best: { href: string; book: string; chapter: string; pct: number; at: number } | null = null;
        for (const slug of Object.keys(map)) {
          let data: any = {};
          try {
            data = JSON.parse(localStorage.getItem('sagas:progress:' + slug) || '{}');
          } catch {}
          const lastId = data._last;
          if (!lastId) continue;
          const ch = map[slug].chapters.find((c) => c.id === lastId);
          const rec = data[lastId];
          if (!ch || !rec) continue;
          if (!best || rec.at > best.at) {
            best = { href: ch.href, book: map[slug].title, chapter: ch.title, pct: rec.pct || 0, at: rec.at };
          }
        }
        if (best) {
          el.href = best.href;
          (el.querySelector('[data-continue-title]') as HTMLElement).textContent = best.chapter;
          (el.querySelector('[data-continue-meta]') as HTMLElement).textContent =
            best.book + (best.pct > 0 ? ' -- ' + best.pct + '% in' : '');
          el.removeAttribute('hidden');
        }
      }
    </script>

    {
      shelves.map(({ shelf, name, blurb, books }) => (
        <section
          class="shelf rise"
          id={name.toLowerCase().replace(/\s+/g, '-')}
        >
          <div class="shelf-head">
            <h2>{name}</h2>
            <span class="count">{books.length}</span>
          </div>
          <p class="blurb">{blurb}</p>

          <ul>
            {books.map((book) => {
              const slug = bookSlug(book.id);
              const count = chapterCount(slug);
              return (
                <li>
                  <a href={withBase(`/books/${slug}`)} class="entry">
                    <span class="entry-top">
                      <span class="book-title">{book.data.title}</span>
                      <span class="pill" data-status={book.data.status}>
                        {STATUS_LABELS[book.data.status]}
                      </span>
                    </span>
                    <span class="synopsis">{book.data.synopsis}</span>
                    <span class="meta">
                      {count > 0 && (
                        <span>
                          {count} chapter{count === 1 ? '' : 's'}
                        </span>
                      )}
                      {book.data.universe && <span>{book.data.universe}</span>}
                      <span>since {formatDate(book.data.startedOn)}</span>
                      <FormatBadges
                        pdfUrl={book.data.pdfUrl}
                        audioUrl={book.data.audioUrl}
                      />
                    </span>
                  </a>
                </li>
              );
            })}

            <li aria-hidden="true" class="ghost-li">
              <div class="entry ghost">
                <span class="entry-top">
                  <span class="skeleton skeleton-line title" />
                  <span class="pill">in the works</span>
                </span>
                <span class="skeleton skeleton-line" style="width: 92%" />
                <span class="skeleton skeleton-line" style="width: 70%" />
              </div>
            </li>
          </ul>

          {shelf === 'fanfic' && (
            <p class="note">
              Everything on this shelf is transformative fan work: free,
              non-commercial, and unaffiliated with the rights holders of the
              universes it borrows.
            </p>
          )}
        </section>
      ))
    }
  </main>
</Base>

<style>
  .hero {
    margin-block: var(--space-xl) var(--space-3xl);
  }

  .hero h1 {
    font-size: var(--text-2xl);
    max-width: 18ch;
    margin-top: var(--space-xs);
  }

  .lede {
    margin-top: var(--space-lg);
    font-size: var(--text-lg);
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 46ch;
  }

  .stats {
    margin-top: var(--space-xl);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md) var(--space-lg);
    font-size: var(--text-sm);
    color: var(--ink-soft);
  }

  .continue {
    display: grid;
    gap: var(--space-2xs);
    margin-bottom: var(--space-2xl);
    padding: var(--space-md) var(--space-lg);
    text-decoration: none;
    color: var(--ink);
    transition:
      border-color var(--duration-base) var(--ease-out),
      transform var(--duration-base) var(--ease-out);
  }

  .continue:hover {
    border-color: var(--flame-dim);
    transform: translateY(-2px);
  }

  .continue-eyebrow {
    font-size: var(--text-sm);
    color: var(--flame);
    font-variant-caps: all-small-caps;
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  .continue-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
  }

  .continue-meta {
    font-size: var(--text-sm);
    color: var(--ink-soft);
  }

  .stats strong {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--flame);
    font-weight: 600;
    margin-right: 0.15em;
  }

  .shelf {
    margin-bottom: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--line);
  }

  .shelf-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
  }

  .shelf-head h2 {
    font-size: var(--text-xl);
  }

  .count {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--ink-faint);
    font-variant-numeric: tabular-nums;
  }

  .blurb {
    margin-top: var(--space-2xs);
    color: var(--ink-soft);
    font-size: var(--text-sm);
    font-style: italic;
  }

  ul {
    list-style: none;
    margin: var(--space-lg) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-md);
    /* multi-column on wider screens: books browse 2-3 up, not a thin stack */
    grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
  }

  .entry {
    height: 100%;
    display: grid;
    gap: var(--space-xs);
    padding: var(--space-md) var(--space-lg);
    background: var(--glass);
    backdrop-filter: blur(var(--blur)) saturate(1.3);
    -webkit-backdrop-filter: blur(var(--blur)) saturate(1.3);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-glass);
    text-decoration: none;
    color: var(--ink);
    transition:
      border-color var(--duration-base) var(--ease-out),
      transform var(--duration-base) var(--ease-out);
  }

  a.entry:hover {
    border-color: var(--flame-dim);
    transform: translateY(-2px);
  }

  .entry-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .book-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--ink);
  }

  a.entry:hover .book-title {
    color: var(--flame);
  }

  .synopsis {
    color: var(--ink-soft);
    max-width: var(--measure);
  }

  .ghost-li {
    grid-column: 1 / -1;
  }

  .ghost {
    background: transparent;
    box-shadow: none;
    border-style: dashed;
  }

  .skeleton-line.title {
    width: 45%;
    height: 1.1em;
  }
</style>
