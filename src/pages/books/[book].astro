---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import {
  SHELVES,
  STATUS_LABELS,
  CHAPTER_STATUS_LABELS,
  bookSlug,
  chapterSlug,
  formatDate,
  withBase,
} from '../../lib/shelf';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map((book) => ({
    params: { book: bookSlug(book.id) },
    props: { book },
  }));
}

const { book } = Astro.props;
const slug = bookSlug(book.id);

const chapters = (
  await getCollection('chapters', (c) => bookSlug(c.id) === slug)
).sort((a, b) => a.data.order - b.data.order);

const { Content } = await render(book);
---

<Base title={`${book.data.title} -- sagas`} description={book.data.synopsis}>
  <main>
    <article class="rise">
      <p class="eyebrow">
        <a href={withBase('/')} class="back">Library</a>
        <span class="sep">/</span>
        {SHELVES[book.data.shelf].name}
      </p>
      <h1>{book.data.title}</h1>
      <p class="meta">
        <span class="pill" data-status={book.data.status}>
          {STATUS_LABELS[book.data.status]}
        </span>
        {book.data.universe && <span>set in: {book.data.universe}</span>}
        <span>since {formatDate(book.data.startedOn)}</span>
      </p>
      <p class="synopsis">{book.data.synopsis}</p>
      <div class="about">
        <Content />
      </div>
    </article>

    <section class="chapters rise">
      <div class="chapters-head">
        <h2>Chapters</h2>
        <span class="count">{chapters.length}</span>
      </div>
      {
        chapters.length === 0 ? (
          <div class="empty">
            <ol class="chapter-list">
              <li aria-hidden="true">
                <span class="num">01</span>
                <span class="skeleton skeleton-line" style="width: 55%" />
                <span class="pill">planned</span>
              </li>
              <li aria-hidden="true">
                <span class="num">02</span>
                <span class="skeleton skeleton-line" style="width: 40%" />
                <span class="pill">planned</span>
              </li>
            </ol>
            <p class="empty-note">
              No chapters yet. This book is still forming; the first chapter
              appears here the moment it is written.
            </p>
          </div>
        ) : (
          <ol class="chapter-list">
            {chapters.map((chapter) => (
              <li>
                <a
                  href={withBase(`/books/${slug}/${chapterSlug(chapter.id)}`)}
                  class="chapter-link"
                >
                  <span class="num">
                    {String(chapter.data.order).padStart(2, '0')}
                  </span>
                  <span class="chapter-title">{chapter.data.title}</span>
                  <span class="pill" data-status={chapter.data.status}>
                    {CHAPTER_STATUS_LABELS[chapter.data.status]}
                  </span>
                </a>
              </li>
            ))}
          </ol>
        )
      }
    </section>
  </main>
</Base>

<style>
  .eyebrow .back {
    color: var(--flame);
    text-decoration: none;
  }

  .eyebrow .back:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .eyebrow .sep {
    color: var(--ink-faint);
    margin-inline: 0.4em;
  }

  h1 {
    font-size: var(--text-2xl);
    margin-top: var(--space-xs);
  }

  .meta {
    margin-top: var(--space-md);
  }

  .synopsis {
    margin-top: var(--space-lg);
    font-size: var(--text-lg);
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: var(--measure);
  }

  .about {
    margin-top: var(--space-lg);
    max-width: var(--measure);
    color: var(--ink-soft);
  }

  .chapters {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--line);
  }

  .chapters-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
  }

  .chapters-head h2 {
    font-size: var(--text-xl);
  }

  .count {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--ink-faint);
    font-variant-numeric: tabular-nums;
  }

  .chapter-list {
    margin: var(--space-lg) 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: var(--space-xs);
  }

  .chapter-list li {
    display: block;
  }

  .chapter-link,
  .chapter-list li[aria-hidden] > * ~ * {
    /* layout shared below */
  }

  .chapter-link {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--line-soft);
    border-radius: var(--radius);
    background: var(--surface-raised);
    text-decoration: none;
    color: var(--ink);
    transition:
      border-color 200ms var(--ease-out),
      transform 200ms var(--ease-out);
  }

  .chapter-link:hover {
    border-color: var(--flame-dim);
    transform: translateX(3px);
  }

  .chapter-list li[aria-hidden] {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-sm) var(--space-md);
    border: 1px dashed var(--line-soft);
    border-radius: var(--radius);
  }

  .num {
    font-family: var(--font-display);
    color: var(--ink-faint);
    font-variant-numeric: tabular-nums;
    flex: none;
  }

  .chapter-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--ink);
    margin-right: auto;
  }

  .chapter-link:hover .chapter-title {
    color: var(--flame);
  }

  .chapter-list li[aria-hidden] .skeleton {
    margin-right: auto;
  }

  .empty-note {
    margin-top: var(--space-lg);
    color: var(--ink-soft);
    max-width: var(--measure);
  }
</style>
