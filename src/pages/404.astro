---
import Base from '../layouts/Base.astro';
import { withBase } from '../lib/shelf';
---

<Base title="Page not found -- sagas" description="This page does not exist.">
  <main>
    <section class="rise">
      <p class="eyebrow">404</p>
      <h1>Not every page is written yet.</h1>
      <p>
        This one does not exist. <a href={withBase('/')}>Back to the shelves</a
        >.
      </p>
    </section>
  </main>
</Base>

<style>
  h1 {
    font-size: var(--text-2xl);
    max-width: 18ch;
  }

  p {
    margin-top: var(--space-lg);
    font-size: var(--text-lg);
    color: var(--ink-soft);
  }
</style>
